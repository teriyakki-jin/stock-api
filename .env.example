# ============================
# NEXUS Stock API — 환경 변수
# ============================
# 복사 후 .env 파일 생성:  cp .env.example .env

# ------ JWT ------
# 256비트 이상 Base64 인코딩 문자열
# 생성: openssl rand -base64 32
JWT_SECRET=your-base64-encoded-jwt-secret-here

# ------ Database (prod) ------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=stock
DB_PASSWORD=stock

# ------ Redis ------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ------ Supabase ------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_DB_URL=jdbc:postgresql://db.your-project.supabase.co:5432/postgres
SUPABASE_DB_USERNAME=postgres
SUPABASE_DB_PASSWORD=your-supabase-db-password

# ------ KIS OpenAPI (선택) ------
# 미설정 시 Yahoo Finance 폴백 + GBM 시뮬레이션으로 동작
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_MOCK=true
